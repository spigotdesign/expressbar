{
	"name": "expressbar",
	"version": "1.0.1",
	"description": "A custom notification bar",
	"author": "Bryan Hoffman",
	"license": "GPL-2.0+",
	"homepage": "https://spigotdesign.com/",
	"scripts": {
		"scss:main": "sass --no-source-map assets/scss/main.scss assets/css/main.css",
		"scss:admin": "sass --no-source-map assets/scss/admin.scss assets/css/admin.css",
		"scss": "npm run scss:main && npm run scss:admin",
		"cssmin:main": "cleancss -o assets/css/main.css assets/css/main.css",
		"cssmin:admin": "cleancss -o assets/css/admin.css assets/css/admin.css",
		"cssmin": "npm-run-all --parallel cssmin:*",
		"uglify-js": "uglifyjs resources/js/app.js -o dist/js/app.js",
		"prod": "npm run cssmin && run uglify-js",
		"watch:scss": "onchange 'resources/scss/**/*.scss' -- npm run scss",
		"watch:js": "onchange 'resources/js/*.js' -- npm run uglify-js",
		"watch": "onchange 'assets/scss/**/*.scss' -- npm run scss"
	},
	"devDependencies": {
		"clean-css-cli": "^5.6.1",
		"npm": "^8.18.0",
		"npm-run-all": "4.1.5",
		"onchange": "^7.1.0",
		"sass": "^1.54.5",
		"uglify-js": "^3.15.4"
	}
}
